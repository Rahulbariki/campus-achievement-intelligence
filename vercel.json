{
  "version": 2,
  "name": "campus-achievement-dashboard",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "campus-achievement-ai/backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "campus-achievement-ai/backend/main.py"
    },
    {
      "src": "/certificate-files/(.*)",
      "dest": "campus-achievement-ai/backend/certificates/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1",
      "check": true
    }
  ]
}
